        <mxCell id="adls" value="&lt;b style=&quot;font-size:16px;&quot;&gt;Azure Data Lake Storage Gen2&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Single shared container&#160;&#183;&#160;Hierarchical namespace&lt;br/&gt;Private endpoint&#160;&#183;&#160;CMK via Key Vault&#160;&#183;&#160;Soft delete&#160;&#183;&#160;Versioning&lt;/span&gt;&lt;br/&gt;&lt;br/&gt;&lt;b&gt;The single physical contract&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;font-style:italic;&quot;&gt;same bytes &#183; two logical views &#183; no copy&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFD335;strokeColor=#A88B00;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
