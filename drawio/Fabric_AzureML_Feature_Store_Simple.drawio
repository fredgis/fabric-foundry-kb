        </mxCell>
        <mxCell id="e_entra_aml" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;strokeColor=#1F2D54;strokeWidth=1;endArrow=open;" edge="1" parent="1" source="entra" target="aml">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
